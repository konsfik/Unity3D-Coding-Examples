# Place this .gitignore at the root of your Unity project

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
.utmp/

# Memory captures & recordings (can be huge and sensitive)
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset Store tools (optional)
# /[Aa]ssets/AssetStoreTools*

# Rider plugin and settings
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio / IDE caches
.vs/
.gradle/

# Autogenerated solution/project files (Unity can regenerate these)
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity crash and debugger metadata
sysinfo.txt
mono_crash.*

# Unity-generated meta for debug DBs
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Builds & exported packages
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta

# Logs
*.log

# Blender backup files (Unity imports .blend directly)
*.blend1
*.blend1.meta

# Addressables defaults
ServerData/
[Aa]ssets/StreamingAssets/aa*
[Aa]ssets/AddressableAssetsData/link.xml*
[Aa]ssets/Addressables_Temp*
[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by tests
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
InitTestScene*.unity*